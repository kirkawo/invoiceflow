@page "/invoices/{id:guid}"
@attribute [Authorize]

@inject InvoiceService InvoiceService
@inject ClientService ClientService
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime
@inject ManualReminderService ReminderService
@inject IOptions<AppOptions> AppOptionsAccessor
@inject InvoiceDeliveryService InvoiceDeliveryService

<PageTitle>Invoice @invoice?.Number - InvoiceFlow</PageTitle>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

@if (invoice is null)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">Invoice @invoice.Number</h1>
            <span class="badge @StatusClass(invoice.Status)" style="font-size: 0.85rem;">@invoice.Status</span>
        </div>
        @if (invoice.Status != InvoiceStatus.Draft)
        {
            var hasLineItems = invoice.LineItems.Count > 0;
            <div class="d-flex flex-column align-items-end gap-1">
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary" disabled="@(!hasLineItems)" title="@(!hasLineItems ? "Add at least one line item to download this invoice." : "")" @onclick="DownloadPdf">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" class="me-1" aria-hidden="true">
                            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                        </svg>
                        Download PDF
                    </button>
                    <button class="btn btn-outline-secondary" disabled="@(!hasLineItems)" title="@(!hasLineItems ? "Add at least one line item to share this invoice." : "")" @onclick="CopyPublicLink">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" class="me-1" aria-hidden="true">
                            <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                        </svg>
                        Share
                    </button>
                </div>
                @if (!hasLineItems)
                {
                    <small class="text-muted">Add at least one line item to download or share this invoice.</small>
                }
            </div>
        }
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Client</div>
                    <div class="fw-medium">@clientName</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Issue Date</div>
                    <div>@invoice.IssueDateUtc.ToShortDateString()</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Due Date</div>
                    <div>@invoice.DueDateUtc.ToShortDateString()</div>
                    @if (DueWarningHelper.GetDueWarning(invoice.Status, invoice.DueDateUtc, _today) is { } warning)
                    {
                        <div><span class="@warning.CssClass" style="font-size:0.85rem;">@warning.Text</span></div>
                    }
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-5">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Currency</div>
                    <div>@invoice.Currency</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Total</div>
                    <div class="fs-5 fw-bold">@invoice.Total.ToString("F2")</div>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(invoice.Notes))
            {
                <hr class="my-3" />
                <div class="row">
                    <div class="col">
                        <div class="text-muted small text-uppercase fw-semibold mb-1">Notes</div>
                        <div class="text-pre-wrap">@invoice.Notes</div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (copied)
    {
        <div class="alert alert-success py-2 small">Public link copied to clipboard.</div>
    }

    <div class="d-flex align-items-center justify-content-between mb-2">
        <h3 class="mb-0">Line Items</h3>
        @if (invoice.Status == InvoiceStatus.Draft)
        {
            <button class="btn btn-primary btn-sm" @onclick="() => ShowAddForm = true" disabled="@ShowAddForm">+ Add Item</button>
        }
    </div>

    @if (ShowAddForm)
    {
        <div class="card mb-3 border-primary">
            <div class="card-body py-3">
                <h6 class="card-title mb-2">New Line Item</h6>
                <div class="row g-2">
                    <div class="col-md-5">
                        <input class="form-control form-control-sm" placeholder="Description" @bind="NewDescription" />
                    </div>
                    <div class="col-md-2">
                        <input class="form-control form-control-sm" type="number" step="0.01" placeholder="Qty" @bind="NewQuantity" />
                    </div>
                    <div class="col-md-2">
                        <input class="form-control form-control-sm" type="number" step="0.01" placeholder="Price" @bind="NewUnitPrice" />
                    </div>
                    <div class="col-md-3 d-flex align-items-center gap-1">
                        <button class="btn btn-success btn-sm" @onclick="AddLineItem" disabled="@saving">Add</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => ShowAddForm = false">Cancel</button>
                    </div>
                </div>
                @if (formError is not null)
                {
                    <div class="text-danger mt-1 small">@formError</div>
                }
            </div>
        </div>
    }

    @if (invoice.LineItems.Count == 0)
    {
        <div class="alert alert-info">No line items yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Amount</th>
                        @if (invoice.Status == InvoiceStatus.Draft)
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in invoice.LineItems)
                    {
                        if (EditingLineItemId == line.Id)
                        {
                            <tr>
                                <td><input class="form-control form-control-sm" @bind="EditDescription" /></td>
                                <td><input class="form-control form-control-sm text-end" type="number" step="0.01" @bind="EditQuantity" /></td>
                                <td><input class="form-control form-control-sm text-end" type="number" step="0.01" @bind="EditUnitPrice" /></td>
                                <td class="text-end">@((EditQuantity * EditUnitPrice).ToString("F2"))</td>
                                <td class="text-end">
                                    <button class="btn btn-success btn-sm me-1" @onclick="() => SaveLineItem(line.Id)" disabled="@saving">Save</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td>@line.Description</td>
                                <td class="text-end">@line.Quantity.ToString("0.##")</td>
                                <td class="text-end">@line.UnitPrice.ToString("F2")</td>
                                <td class="text-end">@line.Amount.ToString("F2")</td>
                                @if (invoice.Status == InvoiceStatus.Draft)
                                {
                                    <td class="text-end">
                                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => StartEdit(line)">Edit</button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(line.Id)" disabled="@saving">Delete</button>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="3" class="text-end">Total:</td>
                        <td class="text-end">@invoice.Total.ToString("F2")</td>
                        @if (invoice.Status == InvoiceStatus.Draft)
                        {
                            <td></td>
                        }
                    </tr>
                </tfoot>
            </table>
        </div>
    }

    @if (invoice.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue or InvoiceStatus.Paid)
    {
        <hr class="my-4" />
        <h3 class="mb-3">Send Invoice</h3>

        @if (deliveryFeedback is not null)
        {
            <div class="alert @deliveryFeedbackCssClass py-2 small">@deliveryFeedback</div>
        }

        <div class="mb-3">
            <label class="form-label">Message (optional)</label>
            <textarea class="form-control" rows="2" @bind="DeliveryCustomMessage"></textarea>
        </div>

        <div class="d-flex align-items-center gap-2 mb-3">
            @{
                var canDeliver = !string.IsNullOrWhiteSpace(clientEmail) && invoice.LineItems.Count > 0;
                var deliverDisabled = !canDeliver || sendingDelivery;
                var deliverTitle = string.IsNullOrWhiteSpace(clientEmail)
                    ? "Client has no email address."
                    : invoice.LineItems.Count == 0
                        ? "Add at least one line item before sending."
                        : "";
            }
            <button class="btn btn-primary" disabled="@deliverDisabled" title="@deliverTitle" @onclick="SendInvoiceEmail">
                @(sendingDelivery ? "Sending..." : "Send Invoice")
            </button>
            @if (!string.IsNullOrWhiteSpace(clientEmail))
            {
                <small class="text-muted">Will be sent to @clientEmail</small>
            }
            else
            {
                <small class="text-danger">Client has no email address.</small>
            }
        </div>

        @if (loadingDeliveries)
        {
            <p class="text-muted small">Loading delivery history...</p>
        }
        else
        {
            <h5 class="mb-2">Delivery History</h5>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Recipient</th>
                            <th>Subject</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (deliveries.Count == 0)
                        {
                            <tr><td colspan="4" class="text-muted text-center">No entries yet.</td></tr>
                        }
                        @foreach (var d in deliveries)
                        {
                            <tr>
                                <td class="text-nowrap">@d.SentAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (d.Status == ReminderStatus.Sent)
                                    {
                                        <span class="badge bg-success">Sent</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Failed</span>
                                    }
                                </td>
                                <td>@d.RecipientEmail</td>
                                <td>@d.Subject</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @if (invoice.Status != InvoiceStatus.Draft)
    {
        <hr class="my-4" />
        <h3 class="mb-3">Reminder</h3>

        @if (reminderFeedback is not null)
        {
            <div class="alert @reminderFeedbackCssClass py-2 small">@reminderFeedback</div>
        }

        <div class="mb-3">
            <label class="form-label">Message (optional)</label>
            <textarea class="form-control" rows="2" @bind="ReminderCustomMessage"></textarea>
        </div>

        <div class="d-flex align-items-center gap-2 mb-3">
            @{
                var canSend = invoice.Status == InvoiceStatus.Overdue && !string.IsNullOrWhiteSpace(clientEmail);
                var sendDisabled = !canSend || sendingReminder;
                var sendTitle = invoice.Status != InvoiceStatus.Overdue
                    ? "Reminders can only be sent for overdue invoices."
                    : string.IsNullOrWhiteSpace(clientEmail)
                        ? "Client has no email address."
                        : "";
            }
            <button class="btn btn-warning" disabled="@sendDisabled" title="@sendTitle" @onclick="SendReminder">
                @(sendingReminder ? "Sending..." : "Send Reminder")
            </button>
            @if (invoice.Status == InvoiceStatus.Overdue)
            {
                if (!string.IsNullOrWhiteSpace(clientEmail))
                {
                    <small class="text-muted">Will be sent to @clientEmail</small>
                }
                else
                {
                    <small class="text-danger">Client has no email address.</small>
                }
            }
            else
            {
                <small class="text-muted">@sendTitle</small>
            }
        </div>

        @if (loadingReminders)
        {
            <p class="text-muted small">Loading reminder history...</p>
        }
        else
        {
            <h5 class="mb-2">Reminder History</h5>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Recipient</th>
                            <th>Subject</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (reminders.Count == 0)
                        {
                            <tr><td colspan="5" class="text-muted text-center">No entries yet.</td></tr>
                        }
                        @foreach (var r in reminders)
                        {
                            <tr>
                                <td class="text-nowrap">@r.SentAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (r.Type == ReminderType.ManualOverdue)
                                    {
                                        <span class="badge bg-primary">Manual</span>
                                    }
                                    else if (r.Type == ReminderType.AutomaticOverdue)
                                    {
                                        <span class="badge bg-secondary">Automatic</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">Invoice Send</span>
                                    }
                                </td>
                                <td>
                                    @if (r.Status == ReminderStatus.Sent)
                                    {
                                        <span class="badge bg-success">Sent</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Failed</span>
                                    }
                                    @if (r.Status == ReminderStatus.Failed && !string.IsNullOrWhiteSpace(r.FailureReason))
                                    {
                                        <br /><small class="text-muted">@r.FailureReason</small>
                                    }
                                </td>
                                <td>@r.RecipientEmail</td>
                                <td>@r.Subject</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    <hr class="my-4" />

    <a href="/invoices" class="btn btn-outline-secondary btn-sm">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" class="me-1" aria-hidden="true">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
        </svg>
        Back to Invoices
    </a>
}

@using InvoiceFlow.Application.Reminders

@code {
    private InvoiceDto? invoice;
    private string? clientName;
    private string? clientEmail;
    private string? error;
    private string? formError;
    private bool saving;
    private bool copied;
    private bool ShowAddForm;

    private bool sendingReminder;
    private string? reminderFeedback;
    private string? reminderFeedbackCssClass;
    private bool loadingReminders;
    private IReadOnlyList<ReminderDto> reminders = [];

    private bool sendingDelivery;
    private string? deliveryFeedback;
    private string? deliveryFeedbackCssClass;
    private bool loadingDeliveries;
    private IReadOnlyList<ReminderDto> deliveries = [];
    private string DeliveryCustomMessage = string.Empty;
    private string ReminderCustomMessage = string.Empty;

    private string NewDescription = string.Empty;
    private decimal NewQuantity = 1;
    private decimal NewUnitPrice;

    private int EditingLineItemId;
    private string EditDescription = string.Empty;
    private decimal EditQuantity = 1;
    private decimal EditUnitPrice;

    [Parameter]
    public Guid Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            await LoadInvoiceAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task LoadInvoiceAsync()
    {
        invoice = await InvoiceService.GetInvoiceAsync(Id);
        if (invoice is null)
        {
            error = "Invoice not found.";
            return;
        }

        var clients = await ClientService.GetClientsAsync();
        var matchedClient = clients.FirstOrDefault(c => c.Id == invoice.ClientId);
        clientName = matchedClient?.Name ?? "Unknown";
        clientEmail = matchedClient?.Email;
        ShowAddForm = false;
        EditingLineItemId = 0;

        if (invoice.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue or InvoiceStatus.Paid)
        {
            await LoadDeliveriesAsync();
        }

        if (invoice.Status != InvoiceStatus.Draft)
        {
            await LoadRemindersAsync();
        }
    }

    private async Task AddLineItem()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(NewDescription))
        {
            formError = "Description is required.";
            return;
        }
        if (NewQuantity <= 0)
        {
            formError = "Quantity must be greater than zero.";
            return;
        }
        if (NewUnitPrice < 0)
        {
            formError = "Unit price cannot be negative.";
            return;
        }

        saving = true;
        try
        {
            await InvoiceService.AddLineItemAsync(Id, NewDescription, NewQuantity, NewUnitPrice);
            NewDescription = string.Empty;
            NewQuantity = 1;
            NewUnitPrice = 0;
            ShowAddForm = false;
            await LoadInvoiceAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void StartEdit(InvoiceLineItemDto line)
    {
        EditingLineItemId = line.Id;
        EditDescription = line.Description;
        EditQuantity = line.Quantity;
        EditUnitPrice = line.UnitPrice;
    }

    private void CancelEdit()
    {
        EditingLineItemId = 0;
    }

    private async Task SaveLineItem(int lineItemId)
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(EditDescription))
        {
            formError = "Description is required.";
            return;
        }
        if (EditQuantity <= 0)
        {
            formError = "Quantity must be greater than zero.";
            return;
        }
        if (EditUnitPrice < 0)
        {
            formError = "Unit price cannot be negative.";
            return;
        }

        saving = true;
        try
        {
            await InvoiceService.UpdateLineItemAsync(Id, lineItemId, EditDescription, EditQuantity, EditUnitPrice);
            EditingLineItemId = 0;
            await LoadInvoiceAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConfirmDelete(int lineItemId)
    {
        if (!await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this line item?"))
            return;

        saving = true;
        try
        {
            await InvoiceService.RemoveLineItemAsync(Id, lineItemId);
            await LoadInvoiceAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void DownloadPdf()
    {
        if (invoice?.LineItems.Count == 0)
            return;

        Navigation.NavigateTo($"/invoices/{Id}/pdf", true);
    }

    private async Task LoadRemindersAsync()
    {
        if (invoice is null) return;
        loadingReminders = true;
        try
        {
            reminders = await ReminderService.GetReminderHistoryAsync(invoice.Id);
        }
        finally
        {
            loadingReminders = false;
        }
    }

    private async Task LoadDeliveriesAsync()
    {
        if (invoice is null) return;
        loadingDeliveries = true;
        try
        {
            deliveries = await InvoiceDeliveryService.GetDeliveryHistoryAsync(invoice.Id);
        }
        finally
        {
            loadingDeliveries = false;
        }
    }

    private async Task SendInvoiceEmail()
    {
        if (invoice is null) return;
        sendingDelivery = true;
        deliveryFeedback = null;
        try
        {
            var message = string.IsNullOrWhiteSpace(DeliveryCustomMessage) ? null : DeliveryCustomMessage;
            await InvoiceDeliveryService.SendInvoiceEmailAsync(invoice.Id, message);
            deliveryFeedback = "Invoice sent successfully.";
            deliveryFeedbackCssClass = "alert-success";
            DeliveryCustomMessage = string.Empty;
            await LoadDeliveriesAsync();
        }
        catch (InvalidOperationException ex)
        {
            deliveryFeedback = ex.Message;
            deliveryFeedbackCssClass = "alert-danger";
        }
        finally
        {
            sendingDelivery = false;
        }
    }

    private async Task SendReminder()
    {
        if (invoice is null) return;
        sendingReminder = true;
        reminderFeedback = null;
        try
        {
            await ReminderService.SendManualReminderAsync(invoice.Id, string.IsNullOrWhiteSpace(ReminderCustomMessage) ? null : ReminderCustomMessage);
            reminderFeedback = "Reminder sent successfully.";
            reminderFeedbackCssClass = "alert-success";
            ReminderCustomMessage = string.Empty;
            await LoadRemindersAsync();
        }
        catch (InvalidOperationException ex)
        {
            reminderFeedback = ex.Message;
            reminderFeedbackCssClass = "alert-danger";
        }
        finally
        {
            sendingReminder = false;
        }
    }

    private async Task CopyPublicLink()
    {
        if (invoice is null || invoice.LineItems.Count == 0 || string.IsNullOrWhiteSpace(invoice.PublicId))
            return;

        var publicBase = AppOptionsAccessor.Value.PublicBaseUrl;
        if (string.IsNullOrWhiteSpace(publicBase))
            publicBase = new Uri(Navigation.BaseUri).GetLeftPart(UriPartial.Authority);
        var publicUrl = $"{publicBase}/invoices/public/{invoice.PublicId}";
        await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", publicUrl);
        copied = true;
        _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => copied = false));
    }

    private DateOnly _today => DateOnly.FromDateTime(DateTime.UtcNow);

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
