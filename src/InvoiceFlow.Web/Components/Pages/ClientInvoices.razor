@page "/clients/{clientId:guid}/invoices"
@attribute [Authorize]

@inject InvoiceService InvoiceService
@inject ClientService ClientService

<PageTitle>Client Invoices - InvoiceFlow</PageTitle>

<h1>Invoices</h1>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

@if (clientName is null)
{
    <p>Loading...</p>
}
else
{
    <p class="lead mb-3">Client: <strong>@clientName</strong></p>

    <a href="/invoices/new/@ClientId" class="btn btn-primary mb-3">Create Invoice</a>

    @if (invoices is null)
    {
        <p>Loading invoices...</p>
    }
    else if (invoices.Count == 0)
    {
        <div class="alert alert-info">No invoices for this client yet.</div>
    }
    else
    {
        @* Desktop table *@
        <div class="d-none d-md-block">
            <table class="table">
                <thead>
                    <tr>
                        <th>Number</th>
                        <th>Status</th>
                        <th>Currency</th>
                        <th>Total</th>
                        <th>Due Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in invoices)
                    {
                        <tr>
                            <td><a href="/invoices/@invoice.Id">@invoice.Number</a></td>
                            <td><span class="badge @StatusClass(invoice.Status)">@invoice.Status</span></td>
                            <td>@invoice.Currency</td>
                            <td>@invoice.Total.ToString("F2")</td>
                            <td>
                                @invoice.DueDateUtc.ToShortDateString()
                                @if (DueWarningHelper.GetDueWarning(invoice.Status, invoice.DueDateUtc, _today) is { } warning)
                                {
                                    <br /><span class="@warning.CssClass" style="font-size:0.8rem;white-space:nowrap;">@warning.Text</span>
                                }
                            </td>
                            <td>@RenderActions(invoice)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Mobile cards *@
        <div class="d-md-none">
            @foreach (var invoice in invoices)
            {
                <div class="invoice-card">
                    <div class="card-row">
                        <span class="card-label">Number</span>
                        <span class="card-value"><a href="/invoices/@invoice.Id">@invoice.Number</a></span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Status</span>
                        <span class="card-value"><span class="badge @StatusClass(invoice.Status)">@invoice.Status</span></span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Amount</span>
                        <span class="card-value">@invoice.Currency @invoice.Total.ToString("F2")</span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Due</span>
                        <span class="card-value">
                            @invoice.DueDateUtc.ToShortDateString()
                            @if (DueWarningHelper.GetDueWarning(invoice.Status, invoice.DueDateUtc, _today) is { } warning)
                            {
                                <br /><span class="@warning.CssClass" style="font-size:0.75rem;">@warning.Text</span>
                            }
                        </span>
                    </div>
                    <div class="card-actions">@RenderActions(invoice)</div>
                </div>
            }
        </div>
    }
}

@code {
    private IReadOnlyList<InvoiceDto>? invoices;
    private string? clientName;
    private string? error;
    private HashSet<Guid> loadingActions = [];

    [Parameter]
    public Guid ClientId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            await LoadClientNameAsync();
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task LoadClientNameAsync()
    {
        var allClients = await ClientService.GetClientsAsync();
        clientName = allClients.FirstOrDefault(c => c.Id == ClientId)?.Name ?? "Unknown";
    }

    private async Task LoadInvoicesAsync()
    {
        var loaded = await InvoiceService.GetClientInvoicesAsync(ClientId);
        invoices = loaded.OrderByDescending(i => i.DueDateUtc).ToList().AsReadOnly();
    }

    private async Task ExecuteAction(Guid invoiceId, Func<Task> action)
    {
        loadingActions.Add(invoiceId);
        error = null;

        try
        {
            await action();
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loadingActions.Remove(invoiceId);
        }
    }

    private Task IssueInvoice(Guid id) =>
        ExecuteAction(id, () => InvoiceService.IssueInvoiceAsync(id));

    private Task MarkPaid(Guid id) =>
        ExecuteAction(id, () => InvoiceService.MarkInvoicePaidAsync(id));

    private Task MarkOverdue(Guid id) =>
        ExecuteAction(id, () => InvoiceService.MarkInvoiceOverdueAsync(id));

    private Task CancelInvoice(Guid id) =>
        ExecuteAction(id, () => InvoiceService.CancelInvoiceAsync(id));

    private DateOnly _today => DateOnly.FromDateTime(DateTime.UtcNow);

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };

    private RenderFragment RenderActions(InvoiceDto invoice) => builder =>
    {
        var disabled = loadingActions.Contains(invoice.Id);

        if (invoice.Status == InvoiceStatus.Draft)
        {
            builder.OpenElement(0, "a");
            builder.AddAttribute(1, "href", $"/invoices/{invoice.Id}");
            builder.AddAttribute(2, "class", "btn btn-sm btn-outline-primary");
            builder.AddContent(3, "Edit");
            builder.CloseElement();

            builder.OpenElement(4, "button");
            builder.AddAttribute(5, "class", "btn btn-sm btn-primary");
            builder.AddAttribute(6, "disabled", disabled);
            builder.AddAttribute(7, "onclick", EventCallback.Factory.Create(this, () => IssueInvoice(invoice.Id)));
            builder.AddContent(8, "Issue");
            builder.CloseElement();

            builder.OpenElement(9, "button");
            builder.AddAttribute(10, "class", "btn btn-sm btn-danger");
            builder.AddAttribute(11, "disabled", disabled);
            builder.AddAttribute(12, "onclick", EventCallback.Factory.Create(this, () => CancelInvoice(invoice.Id)));
            builder.AddContent(13, "Cancel");
            builder.CloseElement();
        }
        else if (invoice.Status == InvoiceStatus.Issued)
        {
            builder.OpenElement(0, "a");
            builder.AddAttribute(1, "href", $"/invoices/{invoice.Id}");
            builder.AddAttribute(2, "class", "btn btn-sm btn-outline-secondary");
            builder.AddContent(3, "View");
            builder.CloseElement();

            builder.OpenElement(4, "button");
            builder.AddAttribute(5, "class", "btn btn-sm btn-success");
            builder.AddAttribute(6, "disabled", disabled);
            builder.AddAttribute(7, "onclick", EventCallback.Factory.Create(this, () => MarkPaid(invoice.Id)));
            builder.AddContent(8, "Paid");
            builder.CloseElement();

            builder.OpenElement(9, "button");
            builder.AddAttribute(10, "class", "btn btn-sm btn-warning");
            builder.AddAttribute(11, "disabled", disabled);
            builder.AddAttribute(12, "onclick", EventCallback.Factory.Create(this, () => MarkOverdue(invoice.Id)));
            builder.AddContent(13, "Overdue");
            builder.CloseElement();

            builder.OpenElement(14, "button");
            builder.AddAttribute(15, "class", "btn btn-sm btn-danger");
            builder.AddAttribute(16, "disabled", disabled);
            builder.AddAttribute(17, "onclick", EventCallback.Factory.Create(this, () => CancelInvoice(invoice.Id)));
            builder.AddContent(18, "Cancel");
            builder.CloseElement();
        }
        else if (invoice.Status == InvoiceStatus.Overdue)
        {
            builder.OpenElement(0, "a");
            builder.AddAttribute(1, "href", $"/invoices/{invoice.Id}");
            builder.AddAttribute(2, "class", "btn btn-sm btn-outline-secondary");
            builder.AddContent(3, "View");
            builder.CloseElement();

            builder.OpenElement(4, "button");
            builder.AddAttribute(5, "class", "btn btn-sm btn-success");
            builder.AddAttribute(6, "disabled", disabled);
            builder.AddAttribute(7, "onclick", EventCallback.Factory.Create(this, () => MarkPaid(invoice.Id)));
            builder.AddContent(8, "Paid");
            builder.CloseElement();

            builder.OpenElement(9, "button");
            builder.AddAttribute(10, "class", "btn btn-sm btn-danger");
            builder.AddAttribute(11, "disabled", disabled);
            builder.AddAttribute(12, "onclick", EventCallback.Factory.Create(this, () => CancelInvoice(invoice.Id)));
            builder.AddContent(13, "Cancel");
            builder.CloseElement();
        }
        else if (invoice.Status is InvoiceStatus.Paid or InvoiceStatus.Cancelled)
        {
            builder.OpenElement(0, "a");
            builder.AddAttribute(1, "href", $"/invoices/{invoice.Id}");
            builder.AddAttribute(2, "class", "btn btn-sm btn-outline-secondary");
            builder.AddContent(3, "View");
            builder.CloseElement();
        }
    };
}