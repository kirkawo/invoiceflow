@page "/clients/{clientId:guid}/invoices"
@attribute [Authorize]
@rendermode InteractiveServer

@inject InvoiceService InvoiceService
@inject ClientService ClientService

<PageTitle>Client Invoices - InvoiceFlow</PageTitle>

<h1>Invoices</h1>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

@if (clientName is null)
{
    <p>Loading...</p>
}
else
{
    <p class="lead mb-3">Client: <strong>@clientName</strong></p>

    <a href="/invoices/new/@ClientId" class="btn btn-primary mb-3">Create Invoice</a>

    @if (invoices is null)
    {
        <p>Loading invoices...</p>
    }
    else if (invoices.Count == 0)
    {
        <div class="alert alert-info">No invoices for this client yet.</div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Number</th>
                    <th>Status</th>
                    <th>Currency</th>
                    <th>Total</th>
                    <th>Due Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in invoices)
                {
                    <tr>
                        <td><a href="/invoices/@invoice.Id">@invoice.Number</a></td>
                        <td>
                            <span class="badge @(invoice.Status switch
                            {
                                InvoiceStatus.Draft => "bg-secondary",
                                InvoiceStatus.Issued => "bg-primary",
                                InvoiceStatus.Paid => "bg-success",
                                InvoiceStatus.Overdue => "bg-warning text-dark",
                                InvoiceStatus.Cancelled => "bg-danger",
                                _ => "bg-secondary"
                            })">@invoice.Status</span>
                        </td>
                        <td>@invoice.Currency</td>
                        <td>@invoice.Total.ToString("F2")</td>
                        <td>@invoice.DueDateUtc.ToShortDateString()</td>
                        <td>
                            @if (invoice.Status == InvoiceStatus.Draft)
                            {
                                <a href="/invoices/@invoice.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                <button class="btn btn-sm btn-primary" @onclick="() => IssueInvoice(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Issue</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => CancelInvoice(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Cancel</button>
                            }
                            @if (invoice.Status == InvoiceStatus.Issued)
                            {
                                <a href="/invoices/@invoice.Id" class="btn btn-sm btn-outline-secondary me-1">View</a>
                                <button class="btn btn-sm btn-success" @onclick="() => MarkPaid(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Mark Paid</button>
                                <button class="btn btn-sm btn-warning" @onclick="() => MarkOverdue(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Mark Overdue</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => CancelInvoice(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Cancel</button>
                            }
                            @if (invoice.Status == InvoiceStatus.Overdue)
                            {
                                <a href="/invoices/@invoice.Id" class="btn btn-sm btn-outline-secondary me-1">View</a>
                                <button class="btn btn-sm btn-success" @onclick="() => MarkPaid(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Mark Paid</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => CancelInvoice(invoice.Id)" disabled="@loadingActions.Contains(invoice.Id)">Cancel</button>
                            }
                            @if (invoice.Status is InvoiceStatus.Paid or InvoiceStatus.Cancelled)
                            {
                                <a href="/invoices/@invoice.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private IReadOnlyList<InvoiceDto>? invoices;
    private string? clientName;
    private string? error;
    private HashSet<Guid> loadingActions = [];

    [Parameter]
    public Guid ClientId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            await LoadClientNameAsync();
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task LoadClientNameAsync()
    {
        var allClients = await ClientService.GetClientsAsync();
        clientName = allClients.FirstOrDefault(c => c.Id == ClientId)?.Name ?? "Unknown";
    }

    private async Task LoadInvoicesAsync()
    {
        var loaded = await InvoiceService.GetClientInvoicesAsync(ClientId);
        invoices = loaded.OrderByDescending(i => i.DueDateUtc).ToList().AsReadOnly();
    }

    private async Task ExecuteAction(Guid invoiceId, Func<Task> action)
    {
        loadingActions.Add(invoiceId);
        error = null;

        try
        {
            await action();
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loadingActions.Remove(invoiceId);
        }
    }

    private Task IssueInvoice(Guid id) =>
        ExecuteAction(id, () => InvoiceService.IssueInvoiceAsync(id));

    private Task MarkPaid(Guid id) =>
        ExecuteAction(id, () => InvoiceService.MarkInvoicePaidAsync(id));

    private Task MarkOverdue(Guid id) =>
        ExecuteAction(id, () => InvoiceService.MarkInvoiceOverdueAsync(id));

    private Task CancelInvoice(Guid id) =>
        ExecuteAction(id, () => InvoiceService.CancelInvoiceAsync(id));
}
