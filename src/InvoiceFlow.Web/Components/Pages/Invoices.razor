@page "/invoices"
@attribute [Authorize]
@rendermode InteractiveServer

@inject InvoiceService InvoiceService
@inject ClientService ClientService
@inject NavigationManager Navigation

<PageTitle>Invoices - InvoiceFlow</PageTitle>

<h1>Invoices</h1>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-2 mb-3 align-items-end">
    <div class="col-12 col-sm-4">
        <label for="clientFilter" class="form-label">Client</label>
        <select id="clientFilter" class="form-select" value="@selectedClientId" @onchange="OnClientFilterChanged">
            <option value="">All clients</option>
            @if (clients is not null)
            {
                @foreach (var c in clients)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-6 col-sm-3">
        <label for="statusFilter" class="form-label">Status</label>
        <select id="statusFilter" class="form-select" value="@selectedStatus" @onchange="OnStatusFilterChanged">
            <option value="">All statuses</option>
            @foreach (var s in Enum.GetValues<InvoiceStatus>())
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>
    <div class="col-6 col-sm-3 d-flex align-items-end pb-1">
        <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
    </div>
</div>

@if (invoices is null)
{
    <p class="text-muted">Loading...</p>
}
else if (invoices.Count == 0)
{
    <div class="alert alert-info">No invoices found.</div>
}
else
{
    @* Desktop table *@
    <div class="d-none d-md-block">
        <table class="table">
            <thead>
                <tr>
                    <th>Number</th>
                    <th>Client</th>
                    <th>Status</th>
                    <th>Currency</th>
                    <th>Total</th>
                    <th>Due Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in invoices)
                {
                    <tr>
                        <td><a href="/invoices/@invoice.Id">@invoice.Number</a></td>
                        <td>@GetClientName(invoice.ClientId)</td>
                        <td><span class="badge @StatusClass(invoice.Status)">@invoice.Status</span></td>
                        <td>@invoice.Currency</td>
                        <td>@invoice.Total.ToString("F2")</td>
                        <td>
                            @invoice.DueDateUtc.ToShortDateString()
                            @if (DueWarningHelper.GetDueWarning(invoice.Status, invoice.DueDateUtc, _today) is { } warning)
                            {
                                <br /><span class="@warning.CssClass" style="font-size:0.8rem;white-space:nowrap;">@warning.Text</span>
                            }
                        </td>
                        <td>
                            @if (invoice.Status == InvoiceStatus.Draft)
                            {
                                <a href="/invoices/@invoice.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            }
                            else
                            {
                                <a href="/invoices/@invoice.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Mobile cards *@
    <div class="d-md-none">
        @foreach (var invoice in invoices)
        {
            <div class="invoice-card">
                <div class="card-row">
                    <span class="card-label">Number</span>
                    <span class="card-value"><a href="/invoices/@invoice.Id">@invoice.Number</a></span>
                </div>
                <div class="card-row">
                    <span class="card-label">Client</span>
                    <span class="card-value">@GetClientName(invoice.ClientId)</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Status</span>
                    <span class="card-value"><span class="badge @StatusClass(invoice.Status)">@invoice.Status</span></span>
                </div>
                <div class="card-row">
                    <span class="card-label">Amount</span>
                    <span class="card-value">@invoice.Currency @invoice.Total.ToString("F2")</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Due</span>
                    <span class="card-value">
                        @invoice.DueDateUtc.ToShortDateString()
                        @if (DueWarningHelper.GetDueWarning(invoice.Status, invoice.DueDateUtc, _today) is { } warning)
                        {
                            <br /><span class="@warning.CssClass" style="font-size:0.75rem;">@warning.Text</span>
                        }
                    </span>
                </div>
                <div class="card-actions">
                    @if (invoice.Status == InvoiceStatus.Draft)
                    {
                        <a href="/invoices/@invoice.Id" class="btn btn-outline-primary">Edit</a>
                    }
                    else
                    {
                        <a href="/invoices/@invoice.Id" class="btn btn-outline-secondary">View</a>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<InvoiceDto>? invoices;
    private IReadOnlyList<ClientDto>? clients;
    private string? error;
    private string selectedClientId = "";
    private string selectedStatus = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            clients = await ClientService.GetClientsAsync();
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task LoadInvoicesAsync()
    {
        Guid? clientId = null;
        InvoiceStatus? status = null;

        if (Guid.TryParse(selectedClientId, out var parsedClientId))
            clientId = parsedClientId;

        if (!string.IsNullOrEmpty(selectedStatus) && Enum.TryParse<InvoiceStatus>(selectedStatus, out var parsedStatus))
            status = parsedStatus;

        try
        {
            invoices = await InvoiceService.GetAllInvoicesAsync(clientId, status);
            error = null;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task OnClientFilterChanged(ChangeEventArgs e)
    {
        selectedClientId = e.Value?.ToString() ?? "";
        await LoadInvoicesAsync();
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? "";
        await LoadInvoicesAsync();
    }

    private string GetClientName(Guid clientId)
    {
        if (clients is null) return "Unknown";
        var client = clients.FirstOrDefault(c => c.Id == clientId);
        return client?.Name ?? "Unknown";
    }

    private async Task ClearFilters()
    {
        selectedClientId = "";
        selectedStatus = "";
        await LoadInvoicesAsync();
    }

    private DateOnly _today => DateOnly.FromDateTime(DateTime.UtcNow);

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}