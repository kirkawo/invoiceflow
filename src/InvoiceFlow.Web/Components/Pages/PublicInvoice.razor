@page "/invoices/public/{publicId}"
@layout BlankLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@inject PublicInvoiceService PublicInvoiceService

<PageTitle>Invoice @invoice?.Number - InvoiceFlow</PageTitle>

@if (error is not null)
{
    <div class="public-invoice-error">
        <div class="public-invoice-container">
            <div class="alert alert-danger mb-0">@error</div>
        </div>
    </div>
}
else if (invoice is null)
{
    <div class="public-invoice-loading">
        <div class="public-invoice-container">
            <p class="text-muted">Loading...</p>
        </div>
    </div>
}
else
{
    <div class="public-invoice">
        <div class="public-invoice-container">
            <div class="invoice-header">
                <div class="invoice-header-left">
                    <h1 class="invoice-title">INVOICE</h1>
                    <span class="invoice-number">#@invoice.Number</span>
                </div>
                <div class="invoice-header-right">
                    <span class="badge @StatusClass(invoice.Status) invoice-status-badge">@invoice.Status</span>
                </div>
            </div>

            <div class="invoice-divider"></div>

            <div class="invoice-meta">
                <div class="invoice-meta-billto">
                    <div class="meta-label">Bill To</div>
                    <div class="meta-value">@invoice.ClientName</div>
                    @if (!string.IsNullOrWhiteSpace(invoice.ClientCompany))
                    {
                        <div class="meta-sub">@invoice.ClientCompany</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(invoice.ClientEmail))
                    {
                        <div class="meta-sub">@invoice.ClientEmail</div>
                    }
                </div>
                <div class="invoice-meta-dates">
                    <div class="meta-row">
                        <span class="meta-label">Issue Date</span>
                        <span class="meta-value">@invoice.IssueDateUtc.ToShortDateString()</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-label">Due Date</span>
                        <span class="meta-value">@invoice.DueDateUtc.ToShortDateString()</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-label">Currency</span>
                        <span class="meta-value">@invoice.Currency</span>
                    </div>
                </div>
            </div>

            <div class="invoice-divider"></div>

            <table class="invoice-table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in invoice.LineItems)
                    {
                        <tr>
                            <td>@line.Description</td>
                            <td class="text-end">@line.Quantity.ToString("0.##")</td>
                            <td class="text-end">@line.UnitPrice.ToString("F2")</td>
                            <td class="text-end">@line.Amount.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="invoice-total-row">
                <span class="total-label">Total</span>
                <span class="total-value">@invoice.Currency @invoice.Total.ToString("F2")</span>
            </div>

            <div class="invoice-divider"></div>

            @if (!string.IsNullOrWhiteSpace(invoice.Notes))
            {
                <div class="invoice-notes">
                    <div class="meta-label">Notes</div>
                    <p class="meta-value">@invoice.Notes</p>
                </div>
                <div class="invoice-divider"></div>
            }

            <div class="invoice-footer">
                This invoice was shared via InvoiceFlow.
            </div>
        </div>
    </div>
}

@code {
    private PublicInvoiceDto? invoice;
    private string? error;

    [Parameter]
    public string PublicId { get; set; } = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            invoice = await PublicInvoiceService.GetPublicInvoiceAsync(PublicId);
            if (invoice is null)
            {
                error = "Invoice not found.";
            }
        }
        catch (Exception)
        {
            error = "Invoice not found.";
        }
    }

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
