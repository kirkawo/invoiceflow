@page "/invoices/public/{publicId}"
@layout BlankLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@inject PublicInvoiceService PublicInvoiceService

<PageTitle>Invoice @invoice?.Number - InvoiceFlow</PageTitle>

@if (error is not null)
{
    <div class="public-invoice-page">
        <div class="public-invoice-card">
            <div class="alert alert-danger mb-0">@error</div>
        </div>
    </div>
}
else if (invoice is null)
{
    <div class="public-invoice-page">
        <div class="public-invoice-card">
            <p class="text-muted mb-0">Loading...</p>
        </div>
    </div>
}
else
{
    <div class="public-invoice-page">
        <div class="public-invoice-card">

            <div class="pi-header">
                <div>
                    <div class="pi-title">INVOICE</div>
                    <div class="pi-number">#@invoice.Number</div>
                </div>
                <span class="badge @StatusClass(invoice.Status) pi-badge">@invoice.Status</span>
            </div>

            <hr class="pi-hr" />

            <div class="pi-meta">
                <div class="pi-meta-billto">
                    <div class="pi-label">Bill To</div>
                    <div class="pi-value">@invoice.ClientName</div>
                    @if (!string.IsNullOrWhiteSpace(invoice.ClientCompany))
                    {
                        <div class="pi-sub">@invoice.ClientCompany</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(invoice.ClientEmail))
                    {
                        <div class="pi-sub">@invoice.ClientEmail</div>
                    }
                </div>
                <div class="pi-meta-dates">
                    <div class="pi-meta-row">
                        <span class="pi-label">Issue Date</span>
                        <span class="pi-value">@invoice.IssueDateUtc.ToShortDateString()</span>
                    </div>
                    <div class="pi-meta-row">
                        <span class="pi-label">Due Date</span>
                        <span class="pi-value">@invoice.DueDateUtc.ToShortDateString()</span>
                    </div>
                    <div class="pi-meta-row">
                        <span class="pi-label">Currency</span>
                        <span class="pi-value">@invoice.Currency</span>
                    </div>
                </div>
            </div>

            <hr class="pi-hr" />

            <div class="table-responsive">
                <table class="pi-table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in invoice.LineItems)
                        {
                            <tr>
                                <td>@line.Description</td>
                                <td class="text-end">@line.Quantity.ToString("0.##")</td>
                                <td class="text-end">@line.UnitPrice.ToString("F2")</td>
                                <td class="text-end">@line.Amount.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pi-total">
                <span class="pi-total-label">Total</span>
                <span class="pi-total-value">@invoice.Currency @invoice.Total.ToString("F2")</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(invoice.Notes))
            {
                <hr class="pi-hr" />
                <div class="pi-notes">
                    <div class="pi-label">Notes</div>
                    <p class="pi-value mb-0">@invoice.Notes</p>
                </div>
            }

            <hr class="pi-hr" />

            <div class="pi-footer">This invoice was shared via InvoiceFlow.</div>

        </div>
    </div>
}

@code {
    private PublicInvoiceDto? invoice;
    private string? error;

    [Parameter]
    public string PublicId { get; set; } = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            invoice = await PublicInvoiceService.GetPublicInvoiceAsync(PublicId);
            if (invoice is null)
            {
                error = "Invoice not found.";
            }
        }
        catch (Exception)
        {
            error = "Invoice not found.";
        }
    }

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
