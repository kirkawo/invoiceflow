@page "/invoices/public/{publicId}"
@layout BlankLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@inject PublicInvoiceService PublicInvoiceService

<PageTitle>Invoice @invoice?.Number - InvoiceFlow</PageTitle>

@if (error is not null)
{
    <div class="public-invoice-page">
        <div class="public-invoice-wrapper">
            <div class="alert alert-danger mb-0">@error</div>
        </div>
    </div>
}
else if (invoice is null)
{
    <div class="public-invoice-page">
        <div class="public-invoice-wrapper">
            <p class="text-muted mb-0">Loading...</p>
        </div>
    </div>
}
else
{
    <div class="public-invoice-page">
        <div class="public-invoice-wrapper">

            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="public-invoice-heading">INVOICE</h1>
                    <div class="text-muted fs-5">#@invoice.Number</div>
                </div>
                <span class="badge @StatusClass(invoice.Status) fs-6">@invoice.Status</span>
            </div>

            <hr class="my-4" />

            <div class="row mb-2">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="public-invoice-label">Bill To</div>
                    <div class="fw-medium">@invoice.ClientName</div>
                    @if (!string.IsNullOrWhiteSpace(invoice.ClientCompany))
                    {
                        <div class="text-muted">@invoice.ClientCompany</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(invoice.ClientEmail))
                    {
                        <div class="text-muted">@invoice.ClientEmail</div>
                    }
                </div>
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-6 public-invoice-label">Issue Date</div>
                        <div class="col-6 text-end">@invoice.IssueDateUtc.ToShortDateString()</div>
                    </div>
                    <div class="row">
                        <div class="col-6 public-invoice-label">Due Date</div>
                        <div class="col-6 text-end">@invoice.DueDateUtc.ToShortDateString()</div>
                    </div>
                    <div class="row">
                        <div class="col-6 public-invoice-label">Currency</div>
                        <div class="col-6 text-end">@invoice.Currency</div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in invoice.LineItems)
                        {
                            <tr>
                                <td>@line.Description</td>
                                <td class="text-end">@line.Quantity.ToString("0.##")</td>
                                <td class="text-end">@line.UnitPrice.ToString("F2")</td>
                                <td class="text-end">@line.Amount.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold fs-5">
                            <td colspan="3" class="text-end">Total:</td>
                            <td class="text-end">@invoice.Currency @invoice.Total.ToString("F2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            @if (!string.IsNullOrWhiteSpace(invoice.Notes))
            {
                <hr class="my-4" />
                <div>
                    <div class="public-invoice-label">Notes</div>
                    <p class="text-pre-wrap mb-0">@invoice.Notes</p>
                </div>
            }

            <hr class="my-4" />

            <div class="text-center text-muted small">
                This invoice was shared via InvoiceFlow.
            </div>

        </div>
    </div>
}

@code {
    private PublicInvoiceDto? invoice;
    private string? error;

    [Parameter]
    public string PublicId { get; set; } = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            invoice = await PublicInvoiceService.GetPublicInvoiceAsync(PublicId);
            if (invoice is null)
            {
                error = "Invoice not found.";
            }
        }
        catch (Exception)
        {
            error = "Invoice not found.";
        }
    }

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
