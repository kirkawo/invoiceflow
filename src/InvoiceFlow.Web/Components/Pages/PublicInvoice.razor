@page "/invoices/public/{publicId}"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@inject PublicInvoiceService PublicInvoiceService

<PageTitle>Invoice - InvoiceFlow</PageTitle>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (invoice is null)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <div class="public-invoice">
        <div class="card mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1 class="mb-1">INVOICE</h1>
                        <h4 class="text-muted">#@invoice.Number</h4>
                    </div>
                    <span class="badge @StatusClass(invoice.Status)" style="font-size: 1rem;">@invoice.Status</span>
                </div>

                <hr />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <h5>Bill To</h5>
                        <p class="mb-0">@invoice.ClientName</p>
                        @if (!string.IsNullOrWhiteSpace(invoice.ClientCompany))
                        {
                            <p class="mb-0">@invoice.ClientCompany</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(invoice.ClientEmail))
                        {
                            <p class="mb-0">@invoice.ClientEmail</p>
                        }
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p class="mb-0"><strong>Issue Date:</strong> @invoice.IssueDateUtc.ToShortDateString()</p>
                        <p class="mb-0"><strong>Due Date:</strong> @invoice.DueDateUtc.ToShortDateString()</p>
                        <p class="mb-0"><strong>Currency:</strong> @invoice.Currency</p>
                    </div>
                </div>

                <table class="table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in invoice.LineItems)
                        {
                            <tr>
                                <td>@line.Description</td>
                                <td class="text-end">@line.Quantity.ToString("0.##")</td>
                                <td class="text-end">@line.UnitPrice.ToString("F2")</td>
                                <td class="text-end">@line.Amount.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="3" class="text-end">Total:</td>
                            <td class="text-end">@invoice.Currency @invoice.Total.ToString("F2")</td>
                        </tr>
                    </tfoot>
                </table>

                @if (!string.IsNullOrWhiteSpace(invoice.Notes))
                {
                    <div class="mt-3">
                        <h5>Notes</h5>
                        <p class="text-muted">@invoice.Notes</p>
                    </div>
                }

                <div class="mt-4 text-muted small">
                    <p>This invoice was shared via InvoiceFlow.</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PublicInvoiceDto? invoice;
    private string? error;

    [Parameter]
    public string PublicId { get; set; } = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            invoice = await PublicInvoiceService.GetPublicInvoiceAsync(PublicId);
            if (invoice is null)
            {
                error = "Invoice not found.";
            }
        }
        catch (Exception)
        {
            error = "Invoice not found.";
        }
    }

    private static string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}
