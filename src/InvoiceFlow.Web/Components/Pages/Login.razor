@page "/login"
@attribute [AllowAnonymous]
@layout Layout.BlankLayout

<PageTitle>Login - InvoiceFlow</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center px-3">
    <div class="auth-container">
        <div class="auth-header">
            <h1 class="auth-heading">InvoiceFlow</h1>
            <p class="auth-subtitle">Sign in to continue</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger" role="alert">@error</div>
        }

        <form method="post" action="/auth/login">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input id="email" name="email" class="form-control" autocomplete="email" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Sign in</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string? error;
    private string returnUrl = "/";

    protected override void OnParametersSet()
    {
        error = Error;

        if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative))
        {
            returnUrl = ReturnUrl;
        }
        else
        {
            returnUrl = "/";
        }
    }
}