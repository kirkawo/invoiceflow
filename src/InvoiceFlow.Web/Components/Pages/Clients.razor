@page "/clients"
@attribute [Authorize]

@inject ClientService ClientService

<PageTitle>Clients - InvoiceFlow</PageTitle>

<div class="page-header">
    <h1 class="mb-0">Clients</h1>
    <a href="/clients/new" class="btn btn-primary">Create Client</a>
</div>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

@if (clients is null)
{
    <p class="text-muted">Loading...</p>
}
else if (clients.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-2">No clients yet.</p>
            <a href="/clients/new" class="btn btn-primary">Create one</a>
        </div>
    </div>
}
else
{
    @* Desktop table *@
    <div class="card d-none d-md-block">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Company</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in clients)
                    {
                        <tr>
                            <td>@client.Name</td>
                            <td>@client.Email</td>
                            <td>@client.CompanyName</td>
                            <td>@client.CreatedAtUtc.ToShortDateString()</td>
                            <td><a href="/clients/@client.Id/invoices" class="btn btn-sm btn-outline-secondary">Invoices</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Mobile cards *@
    <div class="d-md-none">
        @foreach (var client in clients)
        {
            <div class="invoice-card">
                <div class="card-row">
                    <span class="card-label">Name</span>
                    <span class="card-value fw-semibold">@client.Name</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Email</span>
                    <span class="card-value">@client.Email</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Company</span>
                    <span class="card-value">@(string.IsNullOrWhiteSpace(client.CompanyName) ? "—" : client.CompanyName)</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Created</span>
                    <span class="card-value">@client.CreatedAtUtc.ToShortDateString()</span>
                </div>
                <div class="card-actions">
                    <a href="/clients/@client.Id/invoices" class="btn btn-outline-secondary">Invoices</a>
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<ClientDto>? clients;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            clients = await ClientService.GetClientsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}
