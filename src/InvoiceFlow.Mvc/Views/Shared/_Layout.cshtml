<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvoiceFlow</title>
    <link rel="stylesheet" href="~/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/app.css" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app-shell">
            <header class="top-app-bar">
                <button type="button" class="menu-btn" aria-label="Toggle navigation menu" onclick="toggleDrawer()">
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                        <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" />
                    </svg>
                </button>

                <span class="app-title">InvoiceFlow</span>

                <div class="top-bar-actions">
                    <form method="post" asp-controller="Auth" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout" aria-label="Log out">
                            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                                <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                            </svg>
                            <span class="logout-label">Logout</span>
                        </button>
                    </form>
                </div>
            </header>

            <div class="body-wrapper">
                <aside id="side-drawer" class="side-drawer" aria-label="Navigation">
                    <nav class="nav-menu">
                        <div class="nav-section-label">Main</div>

                        <div class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index" onclick="closeDrawer()">
                                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                                </svg>
                                <span>Dashboard</span>
                            </a>
                        </div>

                        <div class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")"
                               asp-controller="Clients" asp-action="Index" onclick="closeDrawer()">
                                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                                </svg>
                                <span>Clients</span>
                            </a>
                        </div>

                        <div class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" ? "active" : "")"
                               asp-controller="Invoices" asp-action="Index" onclick="closeDrawer()">
                                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                                    <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z" />
                                </svg>
                                <span>Invoices</span>
                            </a>
                        </div>
                    </nav>
                </aside>

                <div id="drawer-backdrop" class="drawer-backdrop" onclick="closeDrawer()" ontouchstart="closeDrawer()"></div>

                <main class="main-content">
                    <div class="content">
                        @RenderBody()
                    </div>
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="auth-layout">
            @RenderBody()
        </div>
    }

    <script src="~/js/site.js"></script>
</body>
</html>
