@model IReadOnlyList<ClientDto>
@{
    ViewData["Title"] = "Clients";
}

<div class="page-header">
    <h1 class="mb-0">Clients</h1>
    <a asp-action="Create" class="btn btn-primary">Create Client</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-2">No clients yet.</p>
            <a asp-action="Create" class="btn btn-primary">Create one</a>
        </div>
    </div>
}
else
{
    <div class="card d-none d-md-block">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Company</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model)
                    {
                        <tr>
                            <td>@client.Name</td>
                            <td>@client.Email</td>
                            <td>@client.CompanyName</td>
                            <td>@client.CreatedAtUtc.ToShortDateString()</td>
                            <td><a asp-action="Invoices" asp-route-clientId="@client.Id" class="btn btn-sm btn-outline-secondary">Invoices</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-md-none">
        @foreach (var client in Model)
        {
            <div class="invoice-card">
                <div class="card-row">
                    <span class="card-label">Name</span>
                    <span class="card-value fw-semibold">@client.Name</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Email</span>
                    <span class="card-value">@client.Email</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Company</span>
                    <span class="card-value">@(string.IsNullOrWhiteSpace(client.CompanyName) ? "—" : client.CompanyName)</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Created</span>
                    <span class="card-value">@client.CreatedAtUtc.ToShortDateString()</span>
                </div>
                <div class="card-actions">
                    <a asp-action="Invoices" asp-route-clientId="@client.Id" class="btn btn-outline-secondary">Invoices</a>
                </div>
            </div>
        }
    </div>
}
