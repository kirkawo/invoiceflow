@using InvoiceFlow.Application.Invoices
@{
    ViewData["Title"] = "Invoices";
    var invoices = (IReadOnlyList<InvoiceDto>)ViewBag.Invoices;
    var clients = (IReadOnlyList<ClientDto>)ViewBag.Clients;
    var selectedClientId = ViewBag.SelectedClientId as string ?? "";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "";
    var today = DateOnly.FromDateTime(DateTime.UtcNow);

    string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };

    string GetClientName(Guid clientId)
    {
        var c = clients.FirstOrDefault(x => x.Id == clientId);
        return c?.Name ?? "Unknown";
    }
}

<h1>Invoices</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form method="get" asp-action="Index" class="row g-2 mb-3 align-items-end">
    <div class="col-12 col-sm-4">
        <label for="clientId" class="form-label">Client</label>
        <select id="clientId" name="clientId" class="form-select" onchange="this.form.submit()">
            <option value="">All clients</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id.ToString() == selectedClientId)">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-6 col-sm-3">
        <label for="status" class="form-label">Status</label>
        <select id="status" name="status" class="form-select" onchange="this.form.submit()">
            <option value="">All statuses</option>
            @foreach (var s in Enum.GetValues<InvoiceStatus>())
            {
                <option value="@s" selected="@(s.ToString() == selectedStatus)">@s</option>
            }
        </select>
    </div>
    <div class="col-6 col-sm-3 d-flex align-items-end pb-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

@if (invoices.Count == 0)
{
    <div class="alert alert-info">No invoices found.</div>
}
else
{
    <div class="d-none d-md-block">
        <table class="table">
            <thead>
                <tr>
                    <th>Number</th>
                    <th>Client</th>
                    <th>Status</th>
                    <th>Currency</th>
                    <th>Total</th>
                    <th>Due Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in invoices)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@invoice.Id">@invoice.Number</a></td>
                        <td>@GetClientName(invoice.ClientId)</td>
                        <td><span class="badge @StatusClass(invoice.Status)">@invoice.Status</span></td>
                        <td>@invoice.Currency</td>
                        <td>@invoice.Total.ToString("F2")</td>
                        <td>@invoice.DueDateUtc.ToShortDateString()</td>
                        <td>
                            @if (invoice.Status == InvoiceStatus.Draft)
                            {
                                <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            }
                            else
                            {
                                <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-md-none">
        @foreach (var invoice in invoices)
        {
            <div class="invoice-card">
                <div class="card-row">
                    <span class="card-label">Number</span>
                    <span class="card-value"><a asp-action="Details" asp-route-id="@invoice.Id">@invoice.Number</a></span>
                </div>
                <div class="card-row">
                    <span class="card-label">Client</span>
                    <span class="card-value">@GetClientName(invoice.ClientId)</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Status</span>
                    <span class="card-value"><span class="badge @StatusClass(invoice.Status)">@invoice.Status</span></span>
                </div>
                <div class="card-row">
                    <span class="card-label">Amount</span>
                    <span class="card-value">@invoice.Currency @invoice.Total.ToString("F2")</span>
                </div>
                <div class="card-row">
                    <span class="card-label">Due</span>
                    <span class="card-value">@invoice.DueDateUtc.ToShortDateString()</span>
                </div>
                <div class="card-actions">
                    @if (invoice.Status == InvoiceStatus.Draft)
                    {
                        <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-outline-primary">Edit</a>
                    }
                    else
                    {
                        <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-outline-secondary">View</a>
                    }
                </div>
            </div>
        }
    </div>
}
