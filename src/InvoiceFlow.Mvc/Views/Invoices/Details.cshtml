@using InvoiceFlow.Application.Invoices
@using InvoiceFlow.Application.Reminders
@{
    ViewData["Title"] = $"Invoice {ViewBag.Invoice?.Number}";
    var invoice = (InvoiceDto)ViewBag.Invoice;
    var clientName = (string)ViewBag.ClientName;
    var clientEmail = ViewBag.ClientEmail as string;
    var reminders = (IReadOnlyList<ReminderDto>)ViewBag.Reminders;
    var deliveries = (IReadOnlyList<ReminderDto>)ViewBag.Deliveries;
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var publicBaseUrl = !string.IsNullOrWhiteSpace(AppOptionsAccessor.Value.PublicBaseUrl)
        ? AppOptionsAccessor.Value.PublicBaseUrl
        : AppOptionsAccessor.Value.BaseUrl;

    string StatusClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => "bg-secondary",
        InvoiceStatus.Issued => "bg-primary",
        InvoiceStatus.Paid => "bg-success",
        InvoiceStatus.Overdue => "bg-warning text-dark",
        InvoiceStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (invoice == null)
{
    <p class="text-muted">Invoice not found.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">Invoice @invoice.Number</h1>
            <span class="badge @StatusClass(invoice.Status)" style="font-size: 0.85rem;">@invoice.Status</span>
        </div>
        @if (invoice.Status != InvoiceStatus.Draft)
        {
            var hasLineItems = invoice.LineItems.Count > 0;
            <div class="d-flex flex-column align-items-end gap-1">
                <div class="d-flex gap-2">
                    <a asp-action="Pdf" asp-route-id="@invoice.Id" class="btn btn-outline-primary @(hasLineItems ? "" : "disabled")"
                       title="@(!hasLineItems ? "Add at least one line item to download this invoice." : "")">
                        Download PDF
                    </a>
                    <button type="button" class="btn btn-outline-secondary" @(hasLineItems ? "" : "disabled")
                            onclick="copyPublicLink('@publicBaseUrl', '@invoice.PublicId')"
                            title="@(!hasLineItems ? "Add at least one line item to share this invoice." : "")">
                        Share
                    </button>
                </div>
                @if (!hasLineItems)
                {
                    <small class="text-muted">Add at least one line item to download or share this invoice.</small>
                }
            </div>
        }
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Client</div>
                    <div class="fw-medium">@clientName</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Issue Date</div>
                    <div>@invoice.IssueDateUtc.ToShortDateString()</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Due Date</div>
                    <div>@invoice.DueDateUtc.ToShortDateString()</div>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-5">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Currency</div>
                    <div>@invoice.Currency</div>
                </div>
                <div class="col-md-3">
                    <div class="text-muted small text-uppercase fw-semibold mb-1">Total</div>
                    <div class="fs-5 fw-bold">@invoice.Total.ToString("F2")</div>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(invoice.Notes))
            {
                <hr class="my-3" />
                <div class="row">
                    <div class="col">
                        <div class="text-muted small text-uppercase fw-semibold mb-1">Notes</div>
                        <div class="text-pre-wrap">@invoice.Notes</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="copy-feedback" class="alert alert-success py-2 small" style="display:none;">Public link copied to clipboard.</div>

    <div class="d-flex align-items-center justify-content-between mb-2">
        <h3 class="mb-0">Line Items</h3>
        @if (invoice.Status == InvoiceStatus.Draft)
        {
            <button class="btn btn-primary btn-sm" onclick="document.getElementById('add-line-item-form').style.display='block'" id="show-add-btn">+ Add Item</button>
        }
    </div>

    <div id="add-line-item-form" style="display:none;" class="card mb-3 border-primary">
        <div class="card-body py-3">
            <h6 class="card-title mb-2">New Line Item</h6>
            <form method="post" asp-action="AddLineItem" asp-route-id="@invoice.Id">
                @Html.AntiForgeryToken()
                <div class="row g-2">
                    <div class="col-md-5">
                        <input class="form-control form-control-sm" name="Description" placeholder="Description" required />
                    </div>
                    <div class="col-md-2">
                        <input class="form-control form-control-sm" name="Quantity" type="number" step="0.01" placeholder="Qty" value="1" required />
                    </div>
                    <div class="col-md-2">
                        <input class="form-control form-control-sm" name="UnitPrice" type="number" step="0.01" placeholder="Price" value="0" required />
                    </div>
                    <div class="col-md-3 d-flex align-items-center gap-1">
                        <button type="submit" class="btn btn-success btn-sm">Add</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('add-line-item-form').style.display='none'">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (invoice.LineItems.Count == 0)
    {
        <div class="alert alert-info">No line items yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Amount</th>
                        @if (invoice.Status == InvoiceStatus.Draft)
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in invoice.LineItems)
                    {
                        <tr>
                            <td>@line.Description</td>
                            <td class="text-end">@line.Quantity.ToString("0.##")</td>
                            <td class="text-end">@line.UnitPrice.ToString("F2")</td>
                            <td class="text-end">@line.Amount.ToString("F2")</td>
                            @if (invoice.Status == InvoiceStatus.Draft)
                            {
                                <td class="text-end">
                                    <form method="post" asp-action="RemoveLineItem" asp-route-id="@invoice.Id" asp-route-lineItemId="@line.Id" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this line item?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="3" class="text-end">Total:</td>
                        <td class="text-end">@invoice.Total.ToString("F2")</td>
                        @if (invoice.Status == InvoiceStatus.Draft)
                        {
                            <td></td>
                        }
                    </tr>
                </tfoot>
            </table>
        </div>
    }

    @if (invoice.Status is InvoiceStatus.Issued or InvoiceStatus.Overdue or InvoiceStatus.Paid)
    {
        <hr class="my-4" />
        <h3 class="mb-3">Send Invoice</h3>

        @if (ViewBag.DeliveryFeedback != null)
        {
            <div class="alert @ViewBag.DeliveryFeedbackCss py-2 small">@ViewBag.DeliveryFeedback</div>
        }

        <form method="post" asp-action="SendInvoice" asp-route-id="@invoice.Id" class="mb-3">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Message (optional)</label>
                <textarea name="CustomMessage" class="form-control" rows="2"></textarea>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button type="submit" class="btn btn-primary"
                        @(!string.IsNullOrWhiteSpace(clientEmail) && invoice.LineItems.Count > 0 ? "" : "disabled")>
                    Send Invoice
                </button>
                @if (!string.IsNullOrWhiteSpace(clientEmail))
                {
                    <small class="text-muted">Will be sent to @clientEmail</small>
                }
                else
                {
                    <small class="text-danger">Client has no email address.</small>
                }
            </div>
        </form>

        <h5 class="mb-2">Delivery History</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Recipient</th>
                        <th>Subject</th>
                    </tr>
                </thead>
                <tbody>
                    @if (deliveries.Count == 0)
                    {
                        <tr><td colspan="4" class="text-muted text-center">No entries yet.</td></tr>
                    }
                    @foreach (var d in deliveries)
                    {
                        <tr>
                            <td class="text-nowrap">@d.SentAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (d.Status == ReminderStatus.Sent)
                                {
                                    <span class="badge bg-success">Sent</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                            </td>
                            <td>@d.RecipientEmail</td>
                            <td>@d.Subject</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (invoice.Status != InvoiceStatus.Draft)
    {
        <hr class="my-4" />
        <h3 class="mb-3">Reminder</h3>

        @if (ViewBag.ReminderFeedback != null)
        {
            <div class="alert @ViewBag.ReminderFeedbackCss py-2 small">@ViewBag.ReminderFeedback</div>
        }

        <form method="post" asp-action="SendReminder" asp-route-id="@invoice.Id" class="mb-3">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Message (optional)</label>
                <textarea name="CustomMessage" class="form-control" rows="2"></textarea>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button type="submit" class="btn btn-warning"
                        @(invoice.Status == InvoiceStatus.Overdue && !string.IsNullOrWhiteSpace(clientEmail) ? "" : "disabled")>
                    Send Reminder
                </button>
                @if (invoice.Status == InvoiceStatus.Overdue && !string.IsNullOrWhiteSpace(clientEmail))
                {
                    <small class="text-muted">Will be sent to @clientEmail</small>
                }
            </div>
        </form>

        <h5 class="mb-2">Reminder History</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Recipient</th>
                        <th>Subject</th>
                    </tr>
                </thead>
                <tbody>
                    @if (reminders.Count == 0)
                    {
                        <tr><td colspan="5" class="text-muted text-center">No entries yet.</td></tr>
                    }
                    @foreach (var r in reminders)
                    {
                        <tr>
                            <td class="text-nowrap">@r.SentAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (r.Type == ReminderType.ManualOverdue)
                                {
                                    <span class="badge bg-primary">Manual</span>
                                }
                                else if (r.Type == ReminderType.AutomaticOverdue)
                                {
                                    <span class="badge bg-secondary">Automatic</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Invoice Send</span>
                                }
                            </td>
                            <td>
                                @if (r.Status == ReminderStatus.Sent)
                                {
                                    <span class="badge bg-success">Sent</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                                @if (r.Status == ReminderStatus.Failed && !string.IsNullOrWhiteSpace(r.FailureReason))
                                {
                                    <br /><small class="text-muted">@r.FailureReason</small>
                                }
                            </td>
                            <td>@r.RecipientEmail</td>
                            <td>@r.Subject</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <hr class="my-4" />

    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Invoices</a>
}

<script>
    function copyPublicLink(baseUrl, publicId) {
        var url = baseUrl + '/invoices/public/' + publicId;
        navigator.clipboard.writeText(url).then(function() {
            var el = document.getElementById('copy-feedback');
            el.style.display = 'block';
            setTimeout(function() { el.style.display = 'none'; }, 3000);
        });
    }
</script>
