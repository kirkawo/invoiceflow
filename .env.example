# PostgreSQL
POSTGRES_DB=invoiceflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# API
API_BASE_URL=http://localhost:5000
API_PORT=5000

# Web
WEB_BASE_URL=http://localhost:5001
WEB_PORT=5001

# App
APP_PUBLIC_BASE_URL=http://localhost:5001

# Bootstrap (first-run admin user creation — only used when BOOTSTRAP_ENABLED=true)
BOOTSTRAP_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=admin@invoiceflow.dev
BOOTSTRAP_ADMIN_PASSWORD=Admin123!

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_FROM=noreply@invoiceflow.com
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_SSL=true
